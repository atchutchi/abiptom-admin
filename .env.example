# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Runtime app connection.
# Em Vercel usa a string Supavisor transaction mode (*.pooler.supabase.com:6543).
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Opcional. Útil para scripts locais, migrations e acessos directos IPv6.
DATABASE_DIRECT_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Resend (email)
RESEND_API_KEY=re_xxxx
RESEND_FROM=ABIPTOM SARL <info@abiptom.gw>

# App
NEXTAUTH_URL=http://localhost:3000
CRON_SECRET=trocar-por-um-segredo-forte
BACKUP_SUPABASE_BUCKET=backups
